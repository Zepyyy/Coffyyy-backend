generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model Bean {
    id           Int          @id @default(autoincrement())
    name         String
    flavors      String[]     @default([])
    rating       Int          @default(0)
    roastLevel   Int          @default(0)
    countries    String[]     @default([])
    cities       String[]     @default([])
    botanic      Botanic      @default(ARABICA)
    varieties    String[]     @default([])
    brands       String[]     @default([])
    status       Status       @default(NEW)
    dominantNote DominantNote @default(FRUITY)
    designation  Designation  @default(PURE_ORIGIN)
    finished     Boolean?
    clientId     String?
    revision     Int          @default(0)
    deletedAt    DateTime?
    createdAt    DateTime     @default(now())
    updatedAt    DateTime     @updatedAt
    brews        Brew[]
    user         User?        @relation(fields: [userId], references: [id])
    userId       Int?

    // Enforced by a partial index: soft-deleted beans may reuse their name.
    @@unique([userId, clientId])
    @@index([userId])
}

model Brew {
    id             Int      @id @default(autoincrement())
    beanWeight     Int?     @default(0)
    espressoWeight Int?     @default(0)
    extractionTime String?  @default("")
    flow           String?  @default("")
    overallRating  Int?     @default(0)
    tasteScore     Int?     @default(0)
    strengthScore  Int?     @default(0)
    grindSize      Int      @default(0)
    date           DateTime
    beanId         Int
    machineId      Int
    clientId       String?
    revision       Int      @default(0)
    deletedAt      DateTime?
    createdAt      DateTime @default(now())
    updatedAt      DateTime @updatedAt
    bean           Bean     @relation(fields: [beanId], references: [id], onDelete: Restrict)
    machine        Machine  @relation(fields: [machineId], references: [id], onDelete: Restrict)
    user           User?    @relation(fields: [userId], references: [id])
    userId         Int?

    @@unique([userId, clientId])
    @@index([userId])
    @@index([beanId])
    @@index([machineId])
}

model Machine {
    id           Int       @id @default(autoincrement())
    name         String
    brand        String    @default("")
    type         String    @default("")
    purchaseDate DateTime?
    model        String    @default("")
    grindRange   String    @default("")
    capacity     String    @default("")
    clientId     String?
    revision     Int       @default(0)
    deletedAt    DateTime?
    createdAt    DateTime  @default(now())
    updatedAt    DateTime  @updatedAt
    brews        Brew[]
    user         User?     @relation(fields: [userId], references: [id])
    userId       Int?

    // Enforced by a partial index: soft-deleted machines may reuse their name.
    @@unique([userId, clientId])
    @@index([userId])
}

model User {
    // Internal owner record; password remains inaccessible to browser roles.
    id              Int             @id @default(autoincrement())
    username        String          @unique @default("")
    password        String
    revisionCounter Int             @default(0)
    brews           Brew[]
    machines        Machine[]
    beans           Bean[]
    importRuns      ImportRun[]
    sessions        Session[]
    syncCodes       SyncCode[]
    changes         Change[]
    pushOperations  PushOperation[]
    createdAt       DateTime        @default(now())
    updatedAt       DateTime        @updatedAt
}

model Change {
    // Append-only; source of truth for sync pull, tombstones, and 7-day recovery. See CONTEXT.md.
    id         Int              @id @default(autoincrement())
    userId     Int
    entityType SyncedEntityType
    serverId   Int
    clientId   String?
    revision   Int
    operation  ChangeOperation
    payload    Json
    createdAt  DateTime         @default(now())
    user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, revision])
}

model PushOperation {
    // Dedup record for one outbox push; distinct from ImportRun (one-time migration import).
    userId      Int
    operationId String
    payloadHash String
    result      Json
    revision    Int?
    createdAt   DateTime @default(now())
    user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@id([userId, operationId])
}

model Session {
    // Cookie session material; token and CSRF values are stored as hashes.
    id              String    @id @default(uuid())
    tokenHash       String    @unique
    csrfTokenHash   String
    userId          Int
    createdAt       DateTime  @default(now())
    lastSeenAt      DateTime  @default(now())
    expiresAt       DateTime
    absoluteExpiresAt DateTime
    revokedAt       DateTime?
    user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([expiresAt])
}

model SyncCode {
    // One active, expiring pairing code per workspace; plaintext never persisted.
    id         String   @id @default(uuid())
    codeHash   String   @unique
    userId     Int      @unique
    createdAt  DateTime @default(now())
    expiresAt  DateTime
    user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ImportRun {
    idempotencyKey String
    userId         Int
    createdAt      DateTime @default(now())
    user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@id([userId, idempotencyKey])
}

enum Status {
    EXCELLENT
    GOOD
    MID
    HORRIBLE
    NEW
}

enum DominantNote {
    FRUITY
    NUTTY
    FLORAL
    SWEET
    SOUR
    SPICES
    ROASTED
    GREEN
}

enum Botanic {
    ARABICA
    ROBUSTA
}

enum Designation {
    PURE_ORIGIN
    BLEND
}

enum SyncedEntityType {
    BEAN
    BREW
    MACHINE
}

enum ChangeOperation {
    CREATE
    UPDATE
    DELETE
}
